generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategoryType {
  EXPENSE
  INCOME

  @@map("category_type")
}

enum TransactionType {
  EXPENSE
  INCOME

  @@map("transaction_type")
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT
  CASH
  PIX
  OTHER

  @@map("payment_method")
}

enum InstallmentStatus {
  OPEN
  PAID
  CANCELED

  @@map("installment_status")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  firebaseUid  String        @unique @map("firebase_uid")
  name         String?
  email        String        @unique
  photoUrl     String?       @map("photo_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  creditCards  CreditCard[]
  categories   Category[]
  transactions Transaction[]
  installments Installment[]

  @@map("users")
}

model CreditCard {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  name           String
  lastFourDigits String?       @map("last_four_digits")
  limitAmount    Decimal       @map("limit_amount") @db.Decimal(12, 2)
  closingDay     Int           @map("closing_day")
  dueDay         Int           @map("due_day")
  color          String?
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  installments   Installment[]

  @@index([userId])
  @@map("credit_cards")
}

model Category {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String
  icon         String?
  color        String?
  type         CategoryType
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([userId, type])
  @@map("categories")
}

model Transaction {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  creditCardId      String?         @map("credit_card_id") @db.Uuid
  categoryId        String          @map("category_id") @db.Uuid
  description       String
  amount            Decimal         @db.Decimal(12, 2)
  transactionType   TransactionType @map("transaction_type")
  paymentMethod     PaymentMethod   @map("payment_method")
  purchaseDate      DateTime        @map("purchase_date") @db.Date
  installmentsCount Int             @default(1) @map("installments_count")
  invoiceStartMonth Int?            @map("invoice_start_month")
  invoiceStartYear  Int?            @map("invoice_start_year")
  notes             String?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard        CreditCard?     @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  category          Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  installments      Installment[]

  @@index([userId])
  @@index([creditCardId])
  @@index([categoryId])
  @@index([userId, purchaseDate])
  @@map("transactions")
}

model Installment {
  id                String            @id @default(uuid()) @db.Uuid
  transactionId     String            @map("transaction_id") @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  creditCardId      String?           @map("credit_card_id") @db.Uuid
  amount            Decimal           @db.Decimal(12, 2)
  installmentNumber Int               @map("installment_number")
  totalInstallments Int               @map("total_installments")
  invoiceMonth      Int               @map("invoice_month")
  invoiceYear       Int               @map("invoice_year")
  status            InstallmentStatus @default(OPEN)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  transaction       Transaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard        CreditCard?       @relation(fields: [creditCardId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([userId])
  @@index([creditCardId])
  @@index([userId, invoiceYear, invoiceMonth])
  @@map("installments")
}
